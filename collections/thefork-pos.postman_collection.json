          "name": "Open Order",
          "request": {
            "name": "Open Order",
            "description": {
              "content": "Called by TheFork to the POS provider's configured receipt opening URL when a reservation is seated, instructing the POS to open an order for the reservation. The POS responds with 204 on success; TheFork may retry on 5xx errors.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "orders"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
